{
  "name": "umbra",
  "version": "1.0.0",
  "description": "Invisible AI assistant for meetings - undetectable during screen share",
  "repository": {
    "type": "git",
    "url": "https://github.com/nedu-m/umbra.git"
  },
  "homepage": "https://github.com/nedu-m/umbra",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "start:hidden": "electron . --start-hidden",
    "build": "electron-builder --publish never",
    "build:mac": "electron-builder --mac dmg --universal --publish never",
    "build:win": "electron-builder --win portable --publish never",
    "dev": "electron . --enable-logging",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "openai": "^4.77.0",
    "dotenv": "^16.3.1",
    "node-window-manager": "^2.2.4",
    "screenshot-desktop": "^1.15.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.25.6"
  },
  "build": {
    "appId": "app.umbra.desktop",
    "productName": "Umbra",
    "publish": {
      "provider": "github"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!.git/**/*",
      "!dist/**/*"
    ],
    "asarUnpack": [
      "node_modules/screenshot-desktop/**/*",
      "node_modules/node-window-manager/**/*"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/chrome.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal"]
        }
      ],
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": true
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/chrome.ico",
      "requestedExecutionLevel": "asInvoker",
      "verifyUpdateCodeSignature": false,
      "publisherName": "Umbra",
      "fileAssociations": []
    },
    "portable": {
      "artifactName": "Umbra.exe"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/chrome.png"
    }
  },
  "author": "nedu-m",
  "contributors": [
    "Shubham Shinde <70743278+shubhamshnd@users.noreply.github.com> (original developer)"
  ],
  "license": "MIT"
}
